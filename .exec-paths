# Paths to add to emacs exec-path, at startup.
#
# See dino/fixup-exec-path

# on Windows I use vfox to manage java versions
C:/Users/dpchi/.vfox/sdks/java/bin
c:/gcloud-sdk/google-cloud-sdk/bin

#  lots of unix utilities here for various purposes
c:/Program Files/Git/usr/bin

# node, prettier, csslint, eslint, etc. (on Windows obvs)
# c:/Users/dpchi/AppData/Roaming/npm
C:/nvm4w/nodejs

c:/Python314

# csharpier
$HOME/.dotnet/tools
$HOME/bind
# aider
$HOME/.local/bin
# fzf obvs
$HOME/.fzf/bin
# shfmt, jsonnetfmt
$HOME/go/bin

# Linux specific paths
/usr/local/bin
/usr/bin
/usr/lib/google-golang/bin
/usr/local/git/current/bin
